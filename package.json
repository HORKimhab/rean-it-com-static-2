{
  "name": "rean-it-com-static-2",
  "private": true,
  "type": "module",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:dry-run": "wrangler deploy --dry-run",
    "build:protected": "node scripts/encrypt.js",
    "build:youtube-data": "node scripts/build-youtube-courses.js",
    "build:production": "npm run build:protected",
    "sync:youtube": "bash scripts/sync-youtube-playlist.sh",
    "sync:youtube:build": "npm run build:youtube-data",
    "verify": "npm run build:protected && npm run deploy:dry-run",
    "prepush": "npm run verify",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "javascript-obfuscator": "^5.4.1",
    "wrangler": "^4.13.2"
  }
}
